# WebQA Agent Configuration - Flash Mode (default)
# This mode uses a lightweight browser exploration engine (Chrome DevTools MCP)
# to execute natural-language test goals in seconds.
# To create this config: webqa-agent init
# Documentation: https://github.com/MigoXLab/webqa-agent

# Engine selection:
#   * flash (default) — Lightweight and fast autonomous browser agent.
#   * standard — Deep AI-driven test generation & execution (LangGraph).
engine: flash

target:
  url: https://baidu.com
  description: Test search functionality
  max_concurrent_tests: 3  # Optional, concurrent business objectives for Flash mode

test_config: # Test configuration
  business_objectives: Verify the search box is visible, type hello, and confirm results page loads
  # Or concurrent goals:
  # business_objectives:
  #   - Verify homepage and core entry points
  #   - Verify end-to-end search flow

  # =========================================================================
  # Standard (Classic) Engine Configuration Options
  # (These options only apply when engine: standard is configured)
  # =========================================================================
  #
  # # Intelligent reflection (optional, default: True)
  # # When enabled, LLM analyzes failed test cases and replans them.
  # enable_reflection: True
  #
  # # Dynamic step generation (optional, adaptive testing)
  # dynamic_step_generation:
  #   enabled: True  # Optional, default: True - Master switch for dynamic generation
  #   max_dynamic_steps: 8  # Optional, default: 8 - Max steps per UI change (range: 3-15)
  #   min_elements_threshold: 2  # Optional, default: 2 - Min new elements to trigger (1=sensitive, 3+=selective)
  #
  # # Custom tools configuration (optional, advanced features)
  # custom_tools:
  #   enabled: []  # Optional: Enable additional testing tools (by step_type)
  #                # Available custom tools: ['lighthouse', 'nuclei', 'traverse_clickable_elements', 'detect_dynamic_links']

llm_config: # LLM configuration, supports OpenAI, Anthropic Claude, and Google Gemini models
  # =========================
  # OpenAI Configuration Example
  # =========================
  api: openai
  model: gpt-5.4  # Primary model for Stage 2 test planning (Recommended)
  filter_model: gpt-4o-mini  # Lightweight model for Stage 1 element filtering (cost-effective)
  api_key: your_openai_api_key  # Or set OPENAI_API_KEY environment variable
  base_url: https://api.openai.com/v1  # Optional, OpenAI default endpoint
  # temperature: 0.1   # Optional, default 0.1 for OpenAI
  # top_p: 0.9       # Optional, nucleus sampling parameter
  # max_tokens: 8192  # Optional, maximum output tokens

  # GPT-5 family reasoning configuration (optional)
  # reasoning:
  #   effort: medium    # minimal | low | medium | high
  #                     # OpenAI auto-calculates reasoning budget internally
  # text:
  #   verbosity: medium  # low | medium | high (GPT-5 only)

  # =========================
  # Anthropic Claude Configuration Example
  # =========================
  # model: claude-sonnet-4-6  # Claude 4.6 Sonnet (Recommended for testing)
  # filter_model: claude-haiku-4-5-20251001  # Claude 4.5 Haiku (Fast & cost-effective filtering)
  # api_key: your_anthropic_api_key  # Or set ANTHROPIC_API_KEY environment variable
  # base_url:  # Optional, leave empty to use Anthropic default
  # temperature: 1.0  # Optional, default 1.0 for Claude (Anthropic best practice)
  #                   # REQUIRED: Must be 1.0 when using Extended Thinking (reasoning.effort)
  # max_tokens: 8192  # Recommended for Claude (required by Anthropic API)
  #                   # IMPORTANT: Must be > Extended Thinking budget_tokens
  #                   # | effort  | budget | recommended max_tokens |
  #                   # |---------|--------|------------------------|
  #                   # | minimal |  1,024 |  2,000 - 3,000         |
  #                   # | low     |  4,096 |  8,000 - 10,000        |
  #                   # | medium  | 10,000 | 20,000 - 25,000        |
  #                   # | high    | 20,000 | 40,000 - 50,000        |

  # Claude extended thinking configuration (optional, maps to thinking.budget_tokens)
  # reasoning:
  #   effort: medium    # minimal | low | medium | high
  #                     # Maps to: minimal=1024, low=4096, medium=10000, high=20000 tokens
  #                     # 'medium' (10000 tokens) recommended for testing scenarios
  #                     # NOTE: Automatically enforces temperature=1.0 when enabled
  #                     # NOTE: Requires max_tokens > budget_tokens (auto-adjusted if needed)

  # =========================
  # Google Gemini Configuration Example (RECOMMENDED)
  # =========================
  # model: gemini-3.1-pro-preview  # Latest Gemini 3 Flash (recommended default)
  # filter_model: gemini-3-flash-preview  # Cost-effective filtering
  # api_key: your_gemini_api_key  # Or set GEMINI_API_KEY environment variable
  # temperature: 1.0  # Default 1.0 for Gemini (Google best practice)
  # max_tokens: 8192  # Recommended for comprehensive test generation
  # top_k: 40  # Optional, Gemini-specific diversity control
  #
  # Gemini reasoning configuration (via OpenAI SDK):
  # reasoning:
  #   effort: medium    # minimal|low|medium|high
  #                     # Gemini uses OpenAI's reasoning_effort parameter
  #                     # Works for both Gemini 2.5 and Gemini 3.x models
  #                     # Mapped to OpenAI-compatible values via SDK
  #
  # base_url: https://generativelanguage.googleapis.com/v1beta/openai/
  #           # Official Gemini OpenAI compatibility endpoint (auto-set if omitted)
  #           # For third-party relay: http://your-relay-service:port/
  #
  # Recommended Gemini Models (with usage scenarios):
  # - gemini-3-flash-preview: Pro-level intelligence at Flash speed (recommended default for general testing)
  # - gemini-3.1-pro-preview: Best for complex reasoning tasks (advanced test generation, edge case detection)

browser_config:
  viewport: {"width": 1280, "height": 720}
  headless: False  # Docker environment will automatically override to True
  language: zh-CN
  # Single-identity cookie injection. Accepts an inline list (each cookie
  # needs `name`, `value`, plus either `domain` or `url`) or a path to a
  # cookies JSON file. Ignored when the top-level `accounts:` block is set —
  # `accounts:` takes priority and supports HttpOnly cookies + runtime
  # switching.
  cookies: []

# accounts: top-level multi-account user pool (Flash mode).
#   * Each entry needs `name` and either `cookies:` (inline list) or
#     `cookies_file:` (relative paths resolve against this YAML's dir).
#   * Mark one account `default: true` to inject its cookies at startup.
#     If none is marked, the first account is auto-promoted (logged warning).
#   * Each cookie dict must have `name`, `value`, and either `domain` or
#     `url` — otherwise the run aborts before the agent starts.
#   * The agent can mid-run call `switch_account(account=..., navigate_url=...)`
#     to swap identity.
# accounts:
#   - name: admin
#     role: Full administrator
#     default: true
#     cookies_file: ./admin-cookies.json
#   - name: viewer
#     role: Read-only user
#     cookies_file: ./viewer-cookies.json

report:
  language: en-US # zh-CN, en-US
  save_screenshots: True  # Whether to enable screenshots. If True, screenshots are saved as local files. If False, screenshots are stored as base64 in the test data.

log:
  level: info
