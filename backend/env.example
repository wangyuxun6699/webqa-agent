# Database
# Option 1: full connection string
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/webqa
# Option 2: separate settings (recommended for K8s; lower priority than DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=webqa

# Redis
# Option 1: full connection string
REDIS_URL=redis://localhost:6379/0
# Option 2: separate settings (recommended for K8s; lower priority than REDIS_URL)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
PROGRESS_CACHE_TTL=43200  # Progress cache TTL (seconds), default 12 hours

# LLM Configuration
LLM_API=openai
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_AVAILABLE_MODELS=gpt-4.1-mini-2025-04-14,gpt-5-mini-2025-08-07,gemini-3-flash-preview
LLM_DEFAULT_MODEL=gpt-5-mini-2025-08-07

# Gen mode (AI exploration) models; leave empty to reuse LLM_AVAILABLE_MODELS
LLM_GEN_MODELS=gemini-3.1-pro-preview,gemini-3-flash-preview,gpt-5.4,claude-sonnet-4-6
LLM_GEN_DEFAULT_MODEL=gemini-3.1-pro-preview

# Per-model API Key / Base URL (optional; overrides defaults)
# Naming: LLM_API_KEY_<MODEL_NORMALIZED> / LLM_BASE_URL_<MODEL_NORMALIZED>
# MODEL_NORMALIZED = model name uppercased, with - and . replaced by _
# e.g. claude-sonnet-4-6 → CLAUDE_SONNET_4_6
# LLM_API_KEY_CLAUDE_SONNET_4_6=sk-xxx
# LLM_BASE_URL_CLAUDE_SONNET_4_6=https://api.boyuerichdata.opensphereai.com/

# Execution Control
JOB_TIMEOUT_SECONDS=7200      # Max execution time per job (seconds)
MAX_CONCURRENT_JOBS=5         # Max concurrent jobs system-wide
DEFAULT_WORKERS=1             # Default parallel cases per job
MAX_WORKERS=5                 # Max parallel cases per job
WEBQA_CASE_TIMEOUT=2400       # Per-case timeout (seconds), default 40 minutes

# Execution Mode: "local" / "docker" / "kubernetes"
# - local: run Agent as subprocess (local development)
# - docker: run Agent in a Docker container (Docker Compose)
# - kubernetes: run Agent as a K8s Job (K8s cluster)
EXECUTION_MODE=local

# Backend callback URL (for Agent job callbacks)
BACKEND_CALLBACK_URL=http://localhost:8000

# Docker mode (only when EXECUTION_MODE=docker)
# DOCKER_AGENT_IMAGE=webqa-agent:latest
# DOCKER_NETWORK=webqa-network
# DOCKER_SHARED_VOLUME=webqa-shared-data

# Notification webhook (URL notified when scheduled tasks finish; leave empty to disable)
# DEFAULT_FEISHU_WEBHOOK_URL=
# FEISHU_WEBHOOK_TIMEOUT_SECONDS=10

# Shared storage (Docker Compose / K8s)
# Local dev: leave empty to use the project `data` directory
# SHARED_STORAGE_PATH=/shared
# SHARED_REPORTS_DIR=reports
# SHARED_LOGS_DIR=logs

# Kubernetes job resource limits (only when EXECUTION_MODE=kubernetes)
# K8S_JOB_CPU_REQUEST=0.5
# K8S_JOB_CPU_LIMIT=2
# K8S_JOB_MEMORY_REQUEST=1Gi
# K8S_JOB_MEMORY_LIMIT=4Gi
