# =============================================================================
# WebQA Docker Compose 环境变量
# 复制此文件为 .env 并填入实际值：cp .env.example .env
# =============================================================================

# LLM Configuration (必填)
LLM_API=openai
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_AVAILABLE_MODELS=gpt-5.4
LLM_DEFAULT_MODEL=gpt-5.4

# Gen 模式可用模型（留空则复用上方模型列表）
# LLM_GEN_MODELS=
# LLM_GEN_DEFAULT_MODEL=

# Execution Control
JOB_TIMEOUT_SECONDS=7200
MAX_CONCURRENT_JOBS=5
WEBQA_CASE_TIMEOUT=2400
