# Copy this file to secret.yaml and fill in your values (base64 encoded).
#
# To encode a value: echo -n "your-value" | base64
#
apiVersion: v1
kind: Secret
metadata:
  name: webqa-secrets
  namespace: webqa
type: Opaque
data:
  # Database credentials
  # echo -n "webqa" | base64 → d2VicWE=
  DB_USER: d2VicWE=
  # echo -n "change-me-in-production" | base64
  DB_PASSWORD: Y2hhbmdlLW1lLWluLXByb2R1Y3Rpb24=

  # Redis password (leave empty if no auth)
  REDIS_PASSWORD: ""

  # LLM API Key
  # echo -n "sk-your-api-key" | base64
  LLM_API_KEY: c2steW91ci1hcGkta2V5
